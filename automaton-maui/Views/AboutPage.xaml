<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutomatonDesigner.Views.AboutPage"
             Title="About"
             BackgroundColor="{StaticResource Base}">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="20" MaximumWidthRequest="600"
                             HorizontalOptions="Center" VerticalOptions="Center">

            <!-- App Name -->
            <Label Text="Automaton Designer"
                   FontSize="32" FontAttributes="Bold"
                   TextColor="{StaticResource Blue}"
                   HorizontalOptions="Center" />

            <Label Text="Version 1.0"
                   FontSize="16"
                   TextColor="{StaticResource Subtext}"
                   HorizontalOptions="Center" />

            <BoxView HeightRequest="1" Color="{StaticResource Surface1}" Margin="0,8" />

            <!-- Description -->
            <Label TextColor="{StaticResource TextColor}" FontSize="15" LineHeight="1.4"
                   HorizontalTextAlignment="Center"
                   Text="A visual tool for designing, simulating, and testing finite automata — DFA, NFA, and ε-NFA. Define automata using a simple DSL, visualize state diagrams on a canvas, step through input strings, and run test suites." />

            <BoxView HeightRequest="1" Color="{StaticResource Surface1}" Margin="0,8" />

            <!-- Tech Stack -->
            <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                <Label Text="Tech Stack"
                       FontSize="18" FontAttributes="Bold"
                       TextColor="{StaticResource Yellow}"
                       HorizontalOptions="Center" />

                <Label TextColor="{StaticResource TextColor}" FontSize="14"
                       HorizontalTextAlignment="Center" LineHeight="1.4"
                       Text="Haskell — Core automaton engine&#x0a;.NET MAUI — Cross-platform UI&#x0a;SkiaSharp — Canvas rendering" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Surface1}" Margin="0,8" />

            <!-- License -->
            <VerticalStackLayout Spacing="4" HorizontalOptions="Center">
                <Label Text="MIT License"
                       FontSize="16" FontAttributes="Bold"
                       TextColor="{StaticResource Green}"
                       HorizontalOptions="Center" />
                <Label Text="© 2025 Automaton Designer Contributors"
                       FontSize="13" TextColor="{StaticResource Subtext}"
                       HorizontalOptions="Center" />
            </VerticalStackLayout>

            <!-- GitHub Link -->
            <Label Text="github.com/rmarinho/Automaton"
                   FontSize="14"
                   TextColor="{StaticResource Blue}"
                   TextDecorations="Underline"
                   HorizontalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnGitHubTapped" />
                </Label.GestureRecognizers>
            </Label>

            <!-- Bottom padding -->
            <BoxView HeightRequest="20" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
