<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AutomatonDesigner.Views.LearnPage"
             Title="Learn"
             BackgroundColor="{StaticResource Base}">

    <ScrollView Padding="20">
        <VerticalStackLayout Spacing="24" MaximumWidthRequest="700">

            <!-- Header -->
            <Label Text="Learn"
                   FontSize="28" FontAttributes="Bold"
                   TextColor="{StaticResource Blue}" />

            <!-- What is a Finite Automaton? -->
            <VerticalStackLayout Spacing="8">
                <Label Text="What is a Finite Automaton?"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="{StaticResource Yellow}" />
                <Label TextColor="{StaticResource TextColor}" FontSize="15" LineHeight="1.4"
                       Text="A finite automaton (FA) is a mathematical model of computation. It consists of a finite set of states, a set of input symbols (alphabet), transition rules, an initial state, and a set of accepting states. The machine reads input one symbol at a time and transitions between states according to its rules. If it ends in an accepting state after reading all input, the string is accepted." />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Surface1}" />

            <!-- Types -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Types of Finite Automata"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="{StaticResource Yellow}" />

                <!-- DFA -->
                <Border BackgroundColor="{StaticResource Surface0}"
                        StrokeShape="RoundRectangle 8" Stroke="{StaticResource Surface1}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="DFA — Deterministic Finite Automaton"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Green}" />
                        <Label TextColor="{StaticResource TextColor}" FontSize="14" LineHeight="1.4"
                               Text="For every state and input symbol there is exactly one transition. No ambiguity — the machine always knows its next state. DFAs are efficient to simulate (linear time) but can require exponentially more states than an equivalent NFA." />
                    </VerticalStackLayout>
                </Border>

                <!-- NFA -->
                <Border BackgroundColor="{StaticResource Surface0}"
                        StrokeShape="RoundRectangle 8" Stroke="{StaticResource Surface1}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="NFA — Nondeterministic Finite Automaton"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Green}" />
                        <Label TextColor="{StaticResource TextColor}" FontSize="14" LineHeight="1.4"
                               Text="A state may have zero, one, or multiple transitions for the same input symbol. The machine &quot;guesses&quot; the right path — it accepts if any possible execution path reaches an accepting state. NFAs are often more compact than DFAs for the same language." />
                    </VerticalStackLayout>
                </Border>

                <!-- ε-NFA -->
                <Border BackgroundColor="{StaticResource Surface0}"
                        StrokeShape="RoundRectangle 8" Stroke="{StaticResource Surface1}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="ε-NFA — NFA with Epsilon Transitions"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Green}" />
                        <Label TextColor="{StaticResource TextColor}" FontSize="14" LineHeight="1.4"
                               Text="Extends the NFA with epsilon (ε) transitions — spontaneous state changes that consume no input. Useful for composing automata (e.g. from regular expressions). Every ε-NFA can be converted to an equivalent NFA and then to a DFA." />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Surface1}" />

            <!-- DSL Format -->
            <VerticalStackLayout Spacing="8">
                <Label Text="DSL Format"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="{StaticResource Yellow}" />
                <Label TextColor="{StaticResource TextColor}" FontSize="14" LineHeight="1.4"
                       Text="The Automaton Designer uses a simple text-based DSL (Domain-Specific Language) to define automata. Each line specifies a component:" />

                <Border BackgroundColor="{StaticResource Crust}"
                        StrokeShape="RoundRectangle 8" Stroke="{StaticResource Surface1}"
                        Padding="16">
                    <Label FontFamily="OpenSansRegular" FontSize="13"
                           TextColor="{StaticResource Green}" LineHeight="1.6"
                           Text="type DFA&#x0a;&#x0a;states q0 q1 q2&#x0a;alphabet a b&#x0a;start q0&#x0a;accept q2&#x0a;&#x0a;transition q0 a q1&#x0a;transition q0 b q0&#x0a;transition q1 a q2&#x0a;transition q1 b q0&#x0a;transition q2 a q2&#x0a;transition q2 b q2" />
                </Border>

                <Label TextColor="{StaticResource Subtext}" FontSize="13" LineHeight="1.4"
                       Text="• type — DFA, NFA, or ENFA&#x0a;• states — space-separated list of state names&#x0a;• alphabet — space-separated input symbols&#x0a;• start — the initial state&#x0a;• accept — space-separated accepting states&#x0a;• transition — source symbol destination (use eps for ε)" />
            </VerticalStackLayout>

            <BoxView HeightRequest="1" Color="{StaticResource Surface1}" />

            <!-- Key Algorithms -->
            <VerticalStackLayout Spacing="12">
                <Label Text="Key Algorithms"
                       FontSize="20" FontAttributes="Bold"
                       TextColor="{StaticResource Yellow}" />

                <Border BackgroundColor="{StaticResource Surface0}"
                        StrokeShape="RoundRectangle 8" Stroke="{StaticResource Surface1}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Epsilon Closure"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Blue}" />
                        <Label TextColor="{StaticResource TextColor}" FontSize="14" LineHeight="1.4"
                               Text="Computes the set of all states reachable from a given state by following only ε-transitions. This is the foundation for simulating ε-NFAs and converting them to NFAs." />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="{StaticResource Surface0}"
                        StrokeShape="RoundRectangle 8" Stroke="{StaticResource Surface1}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Subset Construction"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Blue}" />
                        <Label TextColor="{StaticResource TextColor}" FontSize="14" LineHeight="1.4"
                               Text="Converts an NFA to an equivalent DFA. Each DFA state represents a set of NFA states. The resulting DFA may have up to 2^n states (where n is the number of NFA states), though in practice it is usually much smaller." />
                    </VerticalStackLayout>
                </Border>

                <Border BackgroundColor="{StaticResource Surface0}"
                        StrokeShape="RoundRectangle 8" Stroke="{StaticResource Surface1}"
                        Padding="16">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="DFA Minimization"
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Blue}" />
                        <Label TextColor="{StaticResource TextColor}" FontSize="14" LineHeight="1.4"
                               Text="Produces the smallest DFA that recognizes the same language. Uses partition refinement (Hopcroft's algorithm) to merge indistinguishable states. The minimal DFA is unique up to state renaming." />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Bottom padding -->
            <BoxView HeightRequest="20" Color="Transparent" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
